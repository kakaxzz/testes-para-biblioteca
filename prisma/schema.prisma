generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Livro {
  id        Int        @id @default(autoincrement())
  titulo    String
  autor     String
  isbn      String     @unique
  sinopse   String?
  capa      String?
  assuntos  String?
  editora   String?
  edicao    String?
  volume    String?
  cdd       String?
  cutter    String?
  criadoEm  DateTime   @default(now())
  exemplares Exemplar[]
}

model Exemplar {
  id         Int          @id @default(autoincrement())
  livroId    Int
  tombo      Int          @unique
  status     String       @default("disponivel")
  criadoEm   DateTime     @default(now())
  livro      Livro        @relation(fields: [livroId], references: [id])
  emprestimos Emprestimo[]
}

model Aluno {
  id          Int          @id @default(autoincrement())
  nome        String
  matricula   String       @unique
  whatsapp    String
  emprestimos Emprestimo[]
}

model Emprestimo {
  id             Int       @id @default(autoincrement())
  alunoId        Int
  exemplarId     Int
  dataEmprestimo DateTime  @default(now())
  dataDevolucao  DateTime?
  aluno          Aluno     @relation(fields: [alunoId], references: [id])
  exemplar       Exemplar  @relation(fields: [exemplarId], references: [id])
}

model Admin {
  id    Int    @id @default(autoincrement())
  email String @unique
  senha String
}

model Tcc {
  id        Int      @id @default(autoincrement())
  titulo    String
  autor     String
  ano       Int
  tipo      String   @default("tcc")
  resumo    String?
  arquivo   String
  criadoEm  DateTime @default(now())
}

model AccessToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}